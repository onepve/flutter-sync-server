# ──────────────────────────────────────────────
# Flutter Server Box 同步服务 — 环境变量配置
# ──────────────────────────────────────────────
# 复制此文件为 .env 并修改配置

# 数据库
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=sync_user
DB_PASSWORD=changeme
DB_NAME=sync_server

# JWT
JWT_SECRET_KEY=generate-a-random-secret-key-here

# 加密盐
ENC_SALT=change-this-salt-too

# SMTP（留空则跳过邮箱验证）
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=user@example.com
SMTP_PASSWORD=your-password
SMTP_FROM=sync@example.com
SMTP_STARTTLS=true     # STARTTLS（端口 587），与 USE_TLS 二选一
# SMTP_USE_TLS=false   # 隐式 SSL/TLS（端口 465），设为 true 时 STARTTLS 失效

# 管理员账号
ADMIN_USERNAME=admin
ADMIN_PASSWORD=strong-admin-password

# 服务端口
SERVER_PORT=8765
